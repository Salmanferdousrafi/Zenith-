// Zenith AI — Database Schema
// Multi-tenant architecture with RAG support

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── AUTHENTICATION ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials provider
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  chatSessions  ChatSession[]
  agents        Agent[]
  knowledgeBases KnowledgeBase[]
  apiKeys       ApiKey[]

  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── AI AGENTS ────────────────────────────────────────────────────

model Agent {
  id          String    @id @default(cuid())
  name        String
  description String?
  systemPrompt String   @db.Text
  model       String    @default("gpt-4-turbo-preview")
  temperature Float     @default(0.7)
  maxTokens   Int       @default(4096)
  tools       Json?     // Array of tool configurations
  isActive    Boolean   @default(true)
  isPublic    Boolean   @default(false)
  avatar      String?
  color       String    @default("#6C5DD3")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Multi-agent relationships
  parentAgentId String?
  parentAgent   Agent?  @relation("AgentHierarchy", fields: [parentAgentId], references: [id])
  subAgents     Agent[] @relation("AgentHierarchy")

  // Knowledge base linkage
  knowledgeBases KnowledgeBase[]

  // Chat sessions using this agent
  chatSessions  ChatSession[]

  @@index([userId])
  @@index([isPublic])
  @@index([isActive])
}

// ─── CHAT SYSTEM ────────────────────────────────────────────────

model ChatSession {
  id        String   @id @default(cuid())
  title     String   @default("New Conversation")
  status    ChatStatus @default(ACTIVE)
  metadata  Json?    // Custom session metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id])

  messages  Message[]

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([updatedAt])
}

model Message {
  id        String   @id @default(cuid())
  role      MessageRole
  content   String   @db.Text
  model     String?  // Which model generated this
  tokens    Int?     // Token count
  latency   Int?     // Response time in ms
  metadata  Json?    // Citations, sources, tool calls, etc.
  createdAt DateTime @default(now())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([role])
  @@index([createdAt])
}

// ─── RAG / KNOWLEDGE BASE ───────────────────────────────────────

model KnowledgeBase {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      KnowledgeStatus @default(PROCESSING)
  documentCount Int    @default(0)
  chunkCount    Int    @default(0)
  vectorDimension Int  @default(1536)
  embeddingModel String @default("text-embedding-3-small")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  documents   Document[]
  agents      Agent[]

  @@index([userId])
  @@index([status])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        DocumentType
  size        Int      // Bytes
  url         String   // S3 URL
  status      DocumentStatus @default(PENDING)
  metadata    Json?    // Extracted metadata (title, author, etc.)
  chunkCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  chunks      DocumentChunk[]

  @@index([knowledgeBaseId])
  @@index([status])
  @@index([type])
}

model DocumentChunk {
  id          String   @id @default(cuid())
  content     String   @db.Text
  embedding   Unsupported("vector(1536)")?  // pgvector
  tokenCount  Int
  metadata    Json?    // Page number, section, etc.
  createdAt   DateTime @default(now())

  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// ─── API KEYS ───────────────────────────────────────────────────

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyHash     String   @unique
  keyPrefix   String   // First 8 chars for display
  scopes      String[] // read, write, admin
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isRevoked   Boolean  @default(false)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@index([isRevoked])
}

// ─── ENUMS ──────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  OWNER
}

enum ChatStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum KnowledgeStatus {
  PROCESSING
  READY
  ERROR
}

enum DocumentType {
  PDF
  DOCX
  TXT
  MD
  HTML
  CSV
  JSON
  CODE
}

enum DocumentStatus {
  PENDING
  PROCESSING
  INDEXED
  ERROR
}
